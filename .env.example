# ============================================================
# Magic Teacher — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.
#
# ---- HOW TO GET SUPABASE VARIABLES ----
# 1. Go to https://supabase.com and sign in
# 2. Create a new project named "magic-teacher-db"
# 3. Wait for the project to finish provisioning (~2 minutes)
# 4. Go to Project Settings → API
#    - NEXT_PUBLIC_SUPABASE_URL  → "Project URL"
#    - NEXT_PUBLIC_SUPABASE_ANON_KEY → "anon public" key under "Project API keys"
#    - SUPABASE_SERVICE_ROLE_KEY → "service_role secret" key (keep this secret!)
# 5. Go to Project Settings → Database → Connection string (URI mode)
#    - Copy the full URI and set it as DATABASE_URL
#    - Replace [YOUR-PASSWORD] in the URI with your database password
#
# ---- HOW TO GET AUTH_SECRET ----
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# NextAuth
AUTH_SECRET=your-auth-secret-here
